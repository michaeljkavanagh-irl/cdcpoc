{
  "name": "postgres-source-connector-sr",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "tasks.max": "1",
    "database.hostname": "host.docker.internal",
    "database.port": "${env:POSTGRES_PORT}",
    "database.user": "${env:POSTGRES_USER}",
    "database.password": "${env:POSTGRES_PASSWORD}",
    "database.dbname": "${env:POSTGRES_DB}",
    "database.server.name": "dev.opusccc",
    "table.include.list": "public.*",
    "plugin.name": "pgoutput",
    "publication.autocreate.mode": "filtered",
    "slot.name": "debezium_northwind_slot_v2_sr",
    "topic.prefix": "northwind-source",
    "key.converter": "io.confluent.connect.avro.AvroConverter",
    "key.converter.schema.registry.url": "http://schema-registry:8081",
    "key.converter.key.subject.name.strategy": "io.confluent.kafka.serializers.subject.TopicRecordNameStrategy",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081",
    "value.converter.value.subject.name.strategy": "io.confluent.kafka.serializers.subject.TopicRecordNameStrategy",
    "snapshot.mode": "no_data",
    "signal.enabled.channels": "source",
    "signal.data.collection": "public.debezium_signal",
    "decimal.handling.mode": "precise",
    "time.precision.mode": "connect",
    "tombstones.on.delete": "true",
    "transforms": "filterProcessInd,routeRows",
    "transforms.filterProcessInd.type": "io.debezium.transforms.Filter",
    "transforms.filterProcessInd.language": "jsr223.groovy",
    "transforms.filterProcessInd.condition": "value == null || value.op == 'd' || value.source == null || value.source.table != 'CMGE_UPLOAD_FILE' || (value.after != null && ((value.after.schema().field('PROCESS_IND') != null && value.after.get('PROCESS_IND') == 'N') || (value.after.schema().field('process_ind') != null && value.after.get('process_ind') == 'N')))",
    "transforms.routeRows.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.routeRows.regex": ".*",
    "transforms.routeRows.replacement": "northwind.clean.topic"
  }
}
